# Force index.html as default directory index (not index.php)
DirectoryIndex index.html

Options +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ---- Laravel API & Auth Routes ----
    RewriteCond %{REQUEST_URI} ^/api/ [OR]
    RewriteCond %{REQUEST_URI} ^/sanctum/
    RewriteRule ^(.*)$ /laravel.php [L]

    # ---- Static files (including storage symlink & Next.js export) ----
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -l [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ---- Dynamic Route Fallbacks ----
    # Serve pre-rendered shell for dynamic routes (Next.js reads actual ID from URL)
    RewriteRule ^meetings/[^/]+/notes/?$ /meetings/0/notes/index.html [L]
    RewriteRule ^meetings/[^/]+/?$ /meetings/0/index.html [L]
    RewriteRule ^tasks/[^/]+/?$ /tasks/0/index.html [L]
    RewriteRule ^work-logs/[^/]+/edit/?$ /work-logs/0/edit/index.html [L]
    RewriteRule ^work-logs/[^/]+/?$ /work-logs/0/index.html [L]

    # ---- SPA Fallback (other routes) ----
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ /index.html [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
